#!/usr/bin/expect -f

set server_ip "62.234.79.188"
set server_user "ubuntu"
set server_password "boX123456"

spawn ssh -o StrictHostKeyChecking=no $server_user@$server_ip

expect "password:"
send "$server_password\r"

expect "$"
send "echo '=== 测试教案保存API ==='\r"

expect "$"
send "cd /var/www/basketball-coach\r"

expect "$"
send "curl -X POST http://localhost:3000/api/plans -H 'Content-Type: application/json' -d '{\"title\":\"测试教案\",\"date\":\"2026-04-15\",\"duration\":90,\"group\":\"U10\",\"location\":\"室内\",\"weather\":\"晴天\",\"theme\":\"运球+投篮\",\"focusSkills\":[\"运球\",\"投篮\"],\"intensity\":\"medium\",\"skillLevel\":\"intermediate\",\"sections\":[{\"name\":\"热身\",\"duration\":10,\"category\":\"warmup\",\"activities\":[{\"name\":\"慢跑\",\"duration\":5,\"description\":\"围绕场地慢跑\"}]}],\"notes\":\"测试教案\",\"generatedBy\":\"rule\",\"playerIds\":[]}'\r"

expect "$"
send "echo '=== 测试完成 ==='\r"

expect "$"
send "exit\r"

expect eof
