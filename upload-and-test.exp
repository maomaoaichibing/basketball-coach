expect "$"
send "  \"sections\": [\r"
expect "$"
send "    {\r"
expect "$"
send "      \"name\": \"热身\",\r"
expect "$"
send "      \"duration\": 10,\r"
expect "$"
send "      \"category\": \"warmup\",\r"
expect "$"
send "      \"activities\": [\r"
expect "$"
send "        {\r"
