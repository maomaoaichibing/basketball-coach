send "          \"description\": \"围绕场地慢跑\"\r"
expect "$"
send "        }\r"
expect "$"
send "      ]\r"
expect "$"
send "    }\r"
expect "$"
send "  ],\r"
expect "$"
send "  \"notes\": \"测试教案\",\r"
expect "$"
send "  \"generatedBy\": \"rule\",\r"
expect "$"
send "  \"playerIds\": []\r"
expect "$"
send "}\r"
expect "$"
send "EOF\r"
expect "$"
send "\r"
expect "$"
send "# 测试API\r"
expect "$"
send "curl -X POST http://localhost:3000/api/plans \\\r"
expect "$"
send "  -H 'Content-Type: application/json' \\\r"
expect "$"
send "  -d @test-plan.json\r"
