send "rm test-plan.json\r"
expect "$"
send "EOF\r"
expect "$"
send "chmod +x test-save-plan.sh\r"
expect "$"
send "./test-save-plan.sh\r"
expect "$"
send "rm test-save-plan.sh\r"
expect "$"
send "exit\r"
