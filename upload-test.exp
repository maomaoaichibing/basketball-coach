#!/usr/bin/expect -f

set server_ip "62.234.79.188"
set server_user "ubuntu"
set server_password "boX123456"

spawn ssh -o StrictHostKeyChecking=no $server_user@$server_ip

expect "password:"
send "$server_password\r"

expect "$"
send "cd /var/www/basketball-coach\r"
expect "$"
send "cat > test-api.sh << 'EOF'\r"
expect "$"
send "#!/bin/bash\r"
expect "$"
send "\r"
expect "$"
send "# 简单测试API\r"
expect "$"
send "echo '=== 测试API响应 ==='\r"
expect "$"
send "\r"
expect "$"
send "# 测试根路径\r"
expect "$"
send "curl -s http://localhost:3000/\r"
expect "$"
send "echo '\\n---'\r"
expect "$"
send "\r"
expect "$"
send "# 测试API路径\r"
expect "$"
send "curl -s http://localhost:3000/api/plans\r"
expect "$"
send "echo '\\n---'\r"
expect "$"
send "\r"
expect "$"
send "echo '=== 测试完成 ==='\r"
expect "$"
send "EOF\r"
expect "$"
send "chmod +x test-api.sh\r"
expect "$"
send "./test-api.sh\r"
expect "$"
send "rm test-api.sh\r"
expect "$"
send "exit\r"
expect eof
