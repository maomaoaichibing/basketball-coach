#!/usr/bin/expect -f

set server_ip "62.234.79.188"
set server_user "ubuntu"
set server_password "boX123456"

spawn ssh -o StrictHostKeyChecking=no $server_user@$server_ip

expect "password:"
send "$server_password\r"

expect "$"
send "cd /var/www/basketball-coach\r"

expect "$"
send "echo '=== 测试教案保存API ==='\r"

expect "$"
send "curl -X POST http://localhost:3000/api/plans -H 'Content-Type: application/json' -d '{"title":"Test Plan","date":"2026-04-15","duration":90,"group":"U10","location":"Indoor","weather":"Sunny","theme":"Dribbling","focusSkills":["Dribbling"],"intensity":"medium","skillLevel":"intermediate","sections":[{"name":"Warmup","duration":10,"category":"warmup","activities":[{"name":"Jogging","duration":5,"description":"Jog around the court"}]}],"notes":"Test plan","generatedBy":"rule","playerIds":[]}'\r"

expect "$"
send "echo '=== 测试完成 ==='\r"
expect "$"
send "exit\r"
expect eof
